# JWT secret for session cookies (любая длинная случайная строка, 32+ символа)
JWT_SECRET=replace-with-long-random-string-min-32-chars

# Bearer-токен, который Android-приложение шлёт в заголовке Authorization
GATEWAY_TOKEN=replace-with-another-long-random-string

# Upstash Redis (auto-injected Vercel'ом после Storage → Marketplace → Upstash Redis)
# Используются ЛИБО KV_* (Vercel KV legacy), ЛИБО UPSTASH_REDIS_* (Upstash напрямую)
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
